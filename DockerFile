
  # Use an official Maven image to build the application
  FROM maven:3.9.6-eclipse-temurin-21 AS builder

  WORKDIR /build

  # Copy pom.xml and download dependencies first for better build caching
  COPY pom.xml .
  RUN mvn dependency:go-offline

  # Copy the source code and build the application
  COPY src ./src
  RUN mvn clean package -DskipTests
  RUN ls  -a /build/target

  # Use a lightweight JDK image for the final runtime
  FROM eclipse-temurin:21-jdk

  WORKDIR /app

  # Copy the built jar from the builder stage
  COPY --from=builder /build/target/products-ms-0.0.1-SNAPSHOT.jar app.jar

  # Expose application HTTP port
  EXPOSE 9090

  # Expose logstash port for documentation purposes
  EXPOSE 5044

  # Run the application with DB config passed as environment variables
  ENTRYPOINT ["sh", "-c", "java -jar \
    -Dspring.datasource.url=$SPRING_DATASOURCE_URL \
    -Dspring.datasource.username=$SPRING_DATASOURCE_USERNAME \
    -Dspring.datasource.password=$SPRING_DATASOURCE_PASSWORD \
    app.jar"]
